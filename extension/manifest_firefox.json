{
  "manifest_version": 2,
  "name": "Unified Platform",
  "version": "2.0.0",
  "description": "Text Captcha · MCQ Exam Solver · Autofill — All-in-one browser assistant",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "downloads",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "unified-platform@extension",
      "strict_min_version": "91.0"
    }
  }
}
