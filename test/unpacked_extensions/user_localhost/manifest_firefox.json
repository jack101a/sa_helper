{
    "manifest_version":  3,
    "name":  "ta-ta User (Local Dev)",
    "version":  "2.2.0",
    "content_security_policy":  {
                                    "extension_pages":  "script-src \u0027self\u0027; object-src \u0027self\u0027"
                                },
    "description":  "Browser assistant for captcha, exam, and autofill workflows",
    "permissions":  [
                        "activeTab",
                        "storage",
                        "unlimitedStorage",
                        "tabs",
                        "downloads",
                        "notifications",
                        "clipboardWrite",
                        "scripting",
                        "alarms",
                        "browsingData",
                        "declarativeNetRequest"
                    ],
    "host_permissions":  [
                             "https://*/*",
                             "http://*/*"
                         ],
    "background":  {
                       "scripts":  [
                                       "background.js"
                                   ]
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "modules/copy_unlocker.js",
                                           "modules/userscript_matcher.js",
                                           "modules/userscript_runtime.js",
                                           "modules/userscript_engine.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "https://sarathi.parivahan.gov.in/*"
                                            ],
                                "js":  [
                                           "modules/dialog_boot.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "https://sarathi.parivahan.gov.in/*"
                                            ],
                                "js":  [
                                           "modules/vcam_inject.js"
                                       ],
                                "run_at":  "document_start",
                                "world":  "MAIN",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "https://sarathi.parivahan.gov.in/*"
                                            ],
                                "js":  [
                                           "modules/main_inject.js"
                                       ],
                                "run_at":  "document_start",
                                "world":  "MAIN",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "https://*/*",
                                                "http://*/*"
                                            ],
                                "js":  [
                                           "modules/shared_utils.js",
                                           "modules/sarathi_harden.js",
                                           "modules/captcha.js",
                                           "modules/exam.js",
                                           "modules/autofill.js",
                                           "modules/stall_automation.js",
                                           "modules/vcam_controller.js",
                                           "content.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "https://sarathi.parivahan.gov.in/*"
                                            ],
                                "js":  [
                                           "modules/sarathi_panel.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            }
                        ],
    "action":  {
                   "default_popup":  "popup/popup.html",
                   "default_icon":  {
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    }
               },
    "icons":  {
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "locator_picker.js"
                                                       ],
                                         "matches":  [
                                                         "https://*/*",
                                                         "http://*/*"
                                                     ]
                                     }
                                 ],
    "browser_specific_settings":  {
                                      "gecko":  {
                                                    "id":  "ta-ta@extension",
                                                    "strict_min_version":  "91.0"
                                                }
                                  }
}
