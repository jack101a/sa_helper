# ─────────────────────────────────────────────
# SA-Helper Docker Environment
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Host paths ────────────────────────────────
# Root directory on the host where all service
# data (logs, config, postgres, redis…) lives.
CONFIG_PATH=/srv/ajaxhs/config

# ── Image ─────────────────────────────────────
SA_HELPER_IMAGE=ghcr.io/jack101a/sa-helper:docker-33

# ── Process identity ──────────────────────────
# UID / GID that containers run as.
# Run `id` on your host to get these values.
PUID=1000
PGID=1000

# ── App behaviour ─────────────────────────────
APP_ENV=production
DEBUG=false

# ── Admin credentials ─────────────────────────
# REQUIRED – must be set, no default.
AUTH_HASH_SALT=changeme_strong_random_salt
ADMIN_TOKEN=changeme_strong_admin_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# ── Database (PostgreSQL) ─────────────────────
POSTGRES_DB=sa_helper
POSTGRES_USER=sa_helper
POSTGRES_PASSWORD=changeme_strong_db_password

# ── Redis ─────────────────────────────────────
REDIS_MAXMEMORY=256mb

# ── Celery worker ─────────────────────────────
WORKER_CONCURRENCY=2
QUEUE_WORKERS=4
EXAM_OCR_CONCURRENCY=2

# ── LiteLLM (leave blank to disable) ──────────
LITELLM_ENDPOINT=
LITELLM_API_KEY=

# ── Telegram bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=true

# Telegram Bot API server credentials
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
