# Generic environment template.
# For Docker production deployment, use `.env.docker.example` as canonical source.

SA_HELPER_IMAGE=ghcr.io/jack101a/sa-helper:latest
CONFIG_PATH=./runtime
PUID=1001
PGID=1001
COMPOSE_PROJECT_NAME=sahelper

# Required security secrets (set strong random values)
AUTH_HASH_SALT=
ADMIN_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Postgres (production)
POSTGRES_DB=sa_helper
POSTGRES_USER=sa_helper
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_TYPE=postgresql
RUN_ALEMBIC_MIGRATIONS=true
CREATE_ALL_TABLES=false

DEBUG=false
LOG_LEVEL=INFO
SOLVE_BACKEND=inprocess
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_MAXMEMORY=512mb
WORKER_CONCURRENCY=2
WORKER_SOLVE_BACKEND=celery_sync
QUEUE_WORKERS=2
MAX_PENDING_TASKS=500
EXAM_OCR_CONCURRENCY=2

LITELLM_ENDPOINT=
LITELLM_API_KEY=

TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
START_TELEGRAM_BOT_IN_API=false
TELEGRAM_BOT_WAIT_FOR_TOKEN=true
TELEGRAM_BOT_TOKEN_POLL_SECONDS=15

BACKUP_POSTGRES_INCLUDE_GLOBALS=false
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_METHOD=age
BACKUP_AGE_RECIPIENT=
BACKUP_GPG_RECIPIENT=
BACKUP_TELEGRAM_ENABLED=false
BACKUP_TELEGRAM_CHAT_ID=
BACKUP_TELEGRAM_SEND_FILE=true
BACKUP_TELEGRAM_MAX_FILE_MB=45
RCLONE_CONFIG=/app/runtime/rclone/rclone.conf
BACKUP_RCLONE_ENABLED=false
BACKUP_RCLONE_DESTINATION=
BACKUP_AUTO_ENABLED=false
BACKUP_SCHEDULE_TYPE=cron
BACKUP_CRON=0 3 * * *
BACKUP_INTERVAL_HOURS=24
BACKUP_TIMEZONE=Asia/Kolkata
BACKUP_RETENTION_DAYS=14
BACKUP_LOCAL_RETENTION_COUNT=10

ADMIN_TRUST_PROXY_IDENTITY=false
ADMIN_SESSION_COOKIE_DOMAIN=
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
