SA_HELPER_IMAGE=ghcr.io/jack101a/sa-helper:latest
API_PORT=8088
COMPOSE_PROJECT_NAME=sahelper
PUID=1001
PGID=1001
CONFIG_PATH=./runtime

# Required secrets (set strong unique values)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=
AUTH_HASH_SALT=

# Postgres
POSTGRES_DB=sa_helper
POSTGRES_USER=sa_helper
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_TYPE=postgresql
RUN_ALEMBIC_MIGRATIONS=true
CREATE_ALL_TABLES=false

# Default solve/runtime mode (no Redis/worker required)
SOLVE_BACKEND=inprocess
REDIS_ENABLED=false

# Telegram bot (dedicated telegram-bot service)
TELEGRAM_BOT_ENABLED=true
START_TELEGRAM_BOT_IN_API=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Optional LLM settings
LITELLM_ENDPOINT=
LITELLM_API_KEY=

# Optional scale profile (only with --profile scale)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_MAXMEMORY=512mb
WORKER_CONCURRENCY=2
WORKER_SOLVE_BACKEND=celery_sync

# Backups
BACKUP_AUTO_ENABLED=false
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_METHOD=age
BACKUP_AGE_RECIPIENT=
BACKUP_GPG_RECIPIENT=
BACKUP_TELEGRAM_ENABLED=false
BACKUP_TELEGRAM_CHAT_ID=
BACKUP_TELEGRAM_SEND_FILE=true
BACKUP_TELEGRAM_MAX_FILE_MB=45
BACKUP_RCLONE_ENABLED=false
BACKUP_RCLONE_DESTINATION=
RCLONE_CONFIG=/app/runtime/rclone/rclone.conf
