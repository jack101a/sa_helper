# â”€â”€â”€ Core Auth â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
AUTH_HASH_SALT=change_me_random_32_chars
ADMIN_TOKEN=your_admin_token_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
PAYLOAD_SIGNER_TOKEN=change_me_random_payload_signer_token
# Optional local/dev override. Docker compose uses the isolated payload-signer service by default.
# PAYLOAD_SIGNER_URL=http://payload-signer:8091
# PAYLOAD_SIGNING_PRIVATE_KEY_PATH=/run/secrets/payload_signing_private.pem
# PAYLOAD_SIGNING_PUBLIC_KEY_PATH=/run/secrets/payload_signing_public.spki.b64
# PAYLOAD_SIGNING_ALLOW_CREATE=false

# â”€â”€â”€ Exam Service â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
LITELLM_ENDPOINT=https://llm.example.com/v1/chat/completions
LITELLM_API_KEY=your_litellm_key
# LITELLM_MODEL=gemma-4-31b-it_gemini  # optional override

# â”€â”€â”€ WhatsApp Alerts (CallMeBot â€” free) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Get your API key: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+91XXXXXXXXXX
CALLMEBOT_APIKEY=your_callmebot_key

# â”€â”€â”€ Telegram Bot â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Discord admin notifications for Telegram payment submissions.
# Create a Discord channel webhook and paste its URL here.
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_ENABLED=true

# â”€â”€â”€ Storage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SQLITE_PATH=backend/logs/app.db
# Distributed Solver Workers
# Default compose uses Redis + one VPS worker. Extra workers can join later by
# using the same REDIS_URL over a private Pangolin/Newt route.
SOLVER_QUEUE_BACKEND=redis
SOLVER_QUEUE_FALLBACK_LOCAL=true
SOLVER_JOB_TIMEOUT_SECONDS=30
SOLVER_WORKER_CONCURRENCY=2
SOLVER_RESULT_TTL_SECONDS=120
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=sa_helper:

# â”€â”€â”€ ONNX Model â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
ONNX_PATH=data/models/model.onnx

# â”€â”€â”€ Server â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
DEBUG=false
RETRAIN_WORKER_ENABLED=false
