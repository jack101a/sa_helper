# ─── Core Auth ────────────────────────────────────────────────────────────────
AUTH_HASH_SALT=change_me_random_32_chars
ADMIN_TOKEN=your_admin_token_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
PAYLOAD_SIGNER_TOKEN=change_me_random_payload_signer_token
# Optional local/dev override. Docker compose uses the isolated payload-signer service by default.
# PAYLOAD_SIGNER_URL=http://payload-signer:8091
# PAYLOAD_SIGNING_PRIVATE_KEY_PATH=/run/secrets/payload_signing_private.pem
# PAYLOAD_SIGNING_ALLOW_CREATE=false

# ─── Exam Service ──────────────────────────────────────────────────────────────
LITELLM_ENDPOINT=https://llm.example.com/v1/chat/completions
LITELLM_API_KEY=your_litellm_key
# LITELLM_MODEL=gemma-4-31b-it_gemini  # optional override

# ─── WhatsApp Alerts (CallMeBot — free) ────────────────────────────────────────
# Get your API key: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+91XXXXXXXXXX
CALLMEBOT_APIKEY=your_callmebot_key

# ─── Telegram Bot ───────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Storage ───────────────────────────────────────────────────────────────────
SQLITE_PATH=backend/logs/app.db

# ─── ONNX Model ────────────────────────────────────────────────────────────────
ONNX_PATH=data/models/model.onnx

# ─── Server ────────────────────────────────────────────────────────────────────
DEBUG=false
RETRAIN_WORKER_ENABLED=false
